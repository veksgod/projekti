                <label asp-for="Pacijent.OdjelId" class="control-label"></label>
                <select asp-for="Pacijent.OdjelId" class="form-control" asp-items="ViewBag.OdjelId"></select>
                <span asp-validation-for="Pacijent.OdjelId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
