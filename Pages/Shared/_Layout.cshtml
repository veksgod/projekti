<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bolnički sustav</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mojstil.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/bolnica_razor_pages.styles.css" asp-append-version="true" />
</head>
<body>

    <partial name="_Header" />

    <nav class="navbar navbar-expand-sm navbar-dark bg-primary mb-3">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">
                Bolnica
            </a>

            <div class="navbar-collapse collapse show">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-page="/Index">
                            Početna
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-page="/Pacijenti/Index">
                            Pacijenti
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-page="/Pacijenti/Filtriranje">
                            Filtriranje
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-page="/Pacijenti/Sortiranje">
                            Sortiranje
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-page="/Odjeli/Index">
                            Odjeli
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <partial name="_Footer" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/mojskript.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>